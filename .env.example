# API 模式（api / chat 生图）必需
OPENAI_API_KEY=sk-your-key-here

# 第三方 API 地址（留空 = 直连 OpenAI 官方，如 OpenRouter 填 https://openrouter.ai/api/v1）
OPENAI_BASE_URL=

# 图片模型名称（留空 = 默认 gpt-image-2；第三方可能需要填如 openai/gpt-5.4-image-2）
OPENAI_IMAGE_MODEL=

# API 模式的代理（可选）
OPENAI_API_IMAGE_PROXY=

# Codex CLI 代理 + URL 参考图下载代理（可选）
CODEX_PROXY=http://127.0.0.1:7890

# 默认生图模式：api | codex（决定 /generate-image 使用哪个脚本）
GENERATE_MODE=api
